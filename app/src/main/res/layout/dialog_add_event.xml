<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="16dp"
    app:cardCornerRadius="16dp"
    app:cardBackgroundColor="#1E1E1E"
    app:strokeWidth="1dp"
    app:strokeColor="#1AFFFFFF"
    app:cardElevation="8dp">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Title -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="เพิ่มบันทึกเตือนความจำ"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold"
                android:gravity="center_horizontal"
                android:layout_marginBottom="12dp" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#1AFFFFFF"
                android:layout_marginBottom="16dp" />

            <!-- Title Input -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="หัวข้อหลัก"
                android:textColor="#B0B0B0"
                android:textSize="12sp"
                android:layout_marginBottom="4dp" />

            <EditText
                android:id="@+id/eventTitleInput"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:hint="เช่น นัดตรวจเช็คระยะรถ"
                android:textColorHint="#55FFFFFF"
                android:textColor="#FFFFFF"
                android:background="@android:drawable/editbox_background_normal"
                android:backgroundTint="#2D2D2D"
                android:paddingLeft="12dp"
                android:paddingRight="12dp"
                android:textSize="14sp"
                android:inputType="text"
                android:layout_marginBottom="16dp" />

            <!-- Description Input -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="รายละเอียด"
                android:textColor="#B0B0B0"
                android:textSize="12sp"
                android:layout_marginBottom="4dp" />

            <EditText
                android:id="@+id/eventDescInput"
                android:layout_width="match_parent"
                android:layout_height="80dp"
                android:hint="รายละเอียดเพิ่มเติม เช่น สถานที่ หรือรายละเอียดอื่นๆ"
                android:textColorHint="#55FFFFFF"
                android:textColor="#FFFFFF"
                android:background="@android:drawable/editbox_background_normal"
                android:backgroundTint="#2D2D2D"
                android:padding="12dp"
                android:textSize="14sp"
                android:gravity="top|left"
                android:inputType="textMultiLine"
                android:layout_marginBottom="16dp" />

            <!-- Date Time Pickers -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="2"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginRight="8dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="เวลาเริ่มต้น"
                        android:textColor="#B0B0B0"
                        android:textSize="12sp"
                        android:layout_marginBottom="4dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnStartTime"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:text="เลือกเวลา"
                        android:textColor="#FFFFFF"
                        android:textSize="12sp"
                        app:strokeWidth="1dp"
                        app:strokeColor="#33FFFFFF"
                        app:backgroundTint="#2D2D2D"
                        app:cornerRadius="6dp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginLeft="8dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="เวลาสิ้นสุด"
                        android:textColor="#B0B0B0"
                        android:textSize="12sp"
                        android:layout_marginBottom="4dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnEndTime"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:text="เลือกเวลา"
                        android:textColor="#FFFFFF"
                        android:textSize="12sp"
                        app:strokeWidth="1dp"
                        app:strokeColor="#33FFFFFF"
                        app:backgroundTint="#2D2D2D"
                        app:cornerRadius="6dp" />
                </LinearLayout>
            </LinearLayout>

            <!-- Popup Reminder Option -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="การเตือนความจำป็อบอัป"
                android:textColor="#B0B0B0"
                android:textSize="12sp"
                android:layout_marginBottom="4dp" />

            <Spinner
                android:id="@+id/reminderSpinner"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:backgroundTint="#FFFFFF"
                android:popupBackground="#1E1E1E"
                android:layout_marginBottom="24dp" />

            <!-- Buttons Action -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="2">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnCancelEvent"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:layout_marginRight="8dp"
                    android:text="ยกเลิก"
                    android:textColor="#FFFFFF"
                    android:textSize="13sp"
                    app:strokeWidth="1dp"
                    app:strokeColor="#33FFFFFF"
                    app:backgroundTint="#2D2D2D"
                    app:cornerRadius="8dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnSaveEvent"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:layout_marginLeft="8dp"
                    android:text="บันทึก"
                    android:textColor="#000000"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    app:backgroundTint="#FFFFFF"
                    app:cornerRadius="8dp" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>
</com.google.android.material.card.MaterialCardView>

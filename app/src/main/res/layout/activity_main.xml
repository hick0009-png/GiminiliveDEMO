<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://tools.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    tools:context=".MainActivity">

    <!-- Fullscreen Camera Preview -->
    <TextureView
        android:id="@+id/textureView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Top Toolbar (Meeting Mode Button) -->
    <ImageButton
        android:id="@+id/btnMeetingMode"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginTop="16dp"
        android:layout_marginStart="16dp"
        android:src="@drawable/ic_meeting_room_24"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="Meeting Mode"
        android:tint="#FFFFFF"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Top Toolbar (Hamburger Menu Button) -->
    <ImageButton
        android:id="@+id/btnMenuMenu"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginTop="16dp"
        android:layout_marginEnd="16dp"
        android:src="@drawable/ic_menu_24"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="Settings Menu"
        android:tint="#FFFFFF"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Toggle Switch for Solo Focus Mode -->
    <androidx.appcompat.widget.SwitchCompat
        android:id="@+id/switchSoloFocus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="โฟกัสผู้ใช้ (Focused)"
        android:textColor="#FFFFFF"
        android:textSize="12sp"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toEndOf="@id/btnMeetingMode"
        app:layout_constraintEnd_toStartOf="@id/btnMenuMenu" />

    <androidx.appcompat.widget.SwitchCompat
        android:id="@+id/switchDateMode"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="วิเคราะห์บทสนทนา (Dating)"
        android:textColor="#FF80F3FF"
        android:textSize="12sp"
        android:textStyle="bold"
        app:layout_constraintTop_toBottomOf="@id/switchSoloFocus"
        app:layout_constraintStart_toStartOf="@id/switchSoloFocus"
        app:layout_constraintEnd_toEndOf="@id/switchSoloFocus" />

    <!-- Center Mic Button & Audio Waves Container -->
    <FrameLayout
        android:id="@+id/micWavesContainer"
        android:layout_width="220dp"
        android:layout_height="220dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/consoleCard"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintVertical_bias="0.6">

        <!-- Outer Wave Layer 2 -->
        <View
            android:id="@+id/wave2"
            android:layout_width="180dp"
            android:layout_height="180dp"
            android:layout_gravity="center"
            android:background="@drawable/wave_bg"
            android:alpha="0" />

        <!-- Inner Wave Layer 1 -->
        <View
            android:id="@+id/wave1"
            android:layout_width="140dp"
            android:layout_height="140dp"
            android:layout_gravity="center"
            android:background="@drawable/wave_bg"
            android:alpha="0" />

        <!-- Microphone Main Button -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/btnMicCenter"
            android:layout_width="96dp"
            android:layout_height="96dp"
            android:layout_gravity="center"
            app:cardCornerRadius="48dp"
            app:cardBackgroundColor="#FFFFFF"
            app:strokeWidth="0dp"
            app:cardElevation="8dp"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground">

            <ImageView
                android:id="@+id/imgMicCenter"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_gravity="center"
                android:src="@drawable/baseline_mic_24"
                app:tint="#000000"
                android:contentDescription="Toggle Mic Session" />
        </com.google.android.material.card.MaterialCardView>
    </FrameLayout>

    <!-- Console Log Card (Centered below the Mic) -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/consoleCard"
        android:layout_width="match_parent"
        android:layout_height="210dp"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:layout_marginBottom="24dp"
        app:cardCornerRadius="16dp"
        app:cardBackgroundColor="#33000000"
        app:strokeWidth="1.5dp"
        app:strokeColor="#40FFFFFF"
        app:cardElevation="0dp"
        app:layout_constraintBottom_toTopOf="@id/btnShutterSingle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">



        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:padding="12dp">

            <!-- Diagnostics Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="6dp"
                android:weightSum="3">

                <TextView
                    android:id="@+id/txtAttentionState"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="ATTENTION: IDLE"
                    android:textColor="#FFB0B0B0"
                    android:textSize="9sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/txtActiveTopic"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="TOPIC: None"
                    android:textColor="#FF4A90E2"
                    android:textSize="9sp"
                    android:textStyle="bold"
                    android:textAlignment="center" />

                <TextView
                    android:id="@+id/txtLastEvent"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="EVENT: None"
                    android:textColor="#FFE57373"
                    android:textSize="9sp"
                    android:textStyle="bold"
                    android:textAlignment="viewEnd" />
            </LinearLayout>

            <!-- Sensor Status Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="6dp"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="SENSORS STATUS: "
                    android:textColor="#80FFFFFF"
                    android:textSize="9sp"
                    android:textStyle="bold"
                    android:layout_marginEnd="6dp"/>

                <Button
                    android:id="@+id/btnMockDriving"
                    style="?android:attr/buttonStyleSmall"
                    android:layout_width="wrap_content"
                    android:layout_height="24dp"
                    android:backgroundTint="#80555555"
                    android:text="Moving Status"
                    android:textColor="#FFFFFF"
                    android:textSize="7sp"
                    android:padding="0dp"
                    android:layout_marginEnd="6dp"
                    android:clickable="false"
                    android:focusable="false" />

                <Button
                    android:id="@+id/btnMockHome"
                    style="?android:attr/buttonStyleSmall"
                    android:layout_width="wrap_content"
                    android:layout_height="24dp"
                    android:backgroundTint="#80555555"
                    android:text="Home/Still Status"
                    android:textColor="#FFFFFF"
                    android:textSize="7sp"
                    android:padding="0dp"
                    android:clickable="false"
                    android:focusable="false" />
            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="CONSOLE LOG"
                android:textColor="#9E9E9E"
                android:textSize="10sp"
                android:textStyle="bold"
                android:layout_marginBottom="4dp"/>

            <ScrollView
                android:id="@+id/logScrollView"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:fillViewport="true">

                <TextView
                    android:id="@+id/chatLog"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="#E0E0E0"
                    android:textSize="12sp"
                    android:fontFamily="monospace" />
            </ScrollView>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Date Insights Card (Premium Pink/Purple theme) -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/dateInsightCard"
        android:layout_width="match_parent"
        android:layout_height="210dp"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:layout_marginBottom="24dp"
        android:visibility="gone"
        app:cardCornerRadius="16dp"
        app:cardBackgroundColor="#224E085A"
        app:strokeWidth="1.5dp"
        app:strokeColor="#80E040FB"
        app:cardElevation="0dp"
        app:layout_constraintBottom_toTopOf="@id/btnShutterSingle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:padding="10dp">

            <!-- Profile Selector & Skill Slot Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="4dp">

                <Spinner
                    android:id="@+id/spinnerProfile"
                    android:layout_width="match_parent"
                    android:layout_height="32dp"
                    android:backgroundTint="#FFE040FB" />
            </LinearLayout>

            <!-- Vibe Temp Progress Bar Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="4dp">

                <TextView
                    android:id="@+id/txtEngagementLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="VIBE TEMP: Warm"
                    android:textColor="#FFE040FB"
                    android:textSize="9sp"
                    android:textStyle="bold"
                    android:layout_marginEnd="8dp" />

                <ProgressBar
                    android:id="@+id/progressEngagementTemp"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="0dp"
                    android:layout_height="6dp"
                    android:layout_weight="1"
                    android:max="100"
                    android:progress="50"
                    android:progressTint="#FFE040FB"/>
            </LinearLayout>

            <!-- Active Agent Info -->
            <TextView
                android:id="@+id/txtAgentInfo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="#80FFFFFF"
                android:textSize="7sp"
                android:layout_marginBottom="2dp" />

            <!-- Likes & Dislikes Chips Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:orientation="horizontal"
                android:layout_marginBottom="4dp"
                android:baselineAligned="false">

                <!-- Likes Container -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginEnd="4dp">
                    
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="❤️ Likes"
                        android:textColor="#FFFF4081"
                        android:textSize="9sp"
                        android:textStyle="bold" />
                        
                    <HorizontalScrollView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scrollbars="none">
                        <LinearLayout
                            android:id="@+id/containerLikesChips"
                            android:layout_width="wrap_content"
                            android:layout_height="match_parent"
                            android:orientation="horizontal"
                            android:gravity="center_vertical" />
                    </HorizontalScrollView>
                </LinearLayout>

                <!-- Dislikes Container -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="❌ Dislikes"
                        android:textColor="#FFE57373"
                        android:textSize="9sp"
                        android:textStyle="bold" />
                        
                    <HorizontalScrollView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scrollbars="none">
                        <LinearLayout
                            android:id="@+id/containerDislikesChips"
                            android:layout_width="wrap_content"
                            android:layout_height="match_parent"
                            android:orientation="horizontal"
                            android:gravity="center_vertical" />
                    </HorizontalScrollView>
                </LinearLayout>
            </LinearLayout>

            <!-- Tip / Suggestions Section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:orientation="vertical"
                android:background="#40000000"
                android:padding="4dp">
                
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="💡 AI SUGGESTION / TIP"
                    android:textColor="#FF00E5FF"
                    android:textSize="8sp"
                    android:textStyle="bold" />
                    
                <ScrollView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">
                    <TextView
                        android:id="@+id/txtDatingTip"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="รอประมวลผลคำแนะนำที่นี่..."
                        android:textColor="#FFFFFF"
                        android:textSize="10sp" />
                </ScrollView>
            </LinearLayout>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Single Camera / Shutter Action Button -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/btnShutterSingle"
        android:layout_width="68dp"
        android:layout_height="68dp"
        android:layout_marginBottom="40dp"
        app:cardCornerRadius="34dp"
        app:cardBackgroundColor="#FFFFFF"
        app:strokeWidth="2dp"
        app:strokeColor="#CCCCCC"
        app:cardElevation="6dp"
        android:clickable="true"
        android:focusable="true"
        android:foreground="?attr/selectableItemBackground"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:id="@+id/imgShutterIcon"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_gravity="center"
            android:src="@drawable/baseline_camera_24"
            app:tint="#000000"
            android:contentDescription="Camera Shutter" />
    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>
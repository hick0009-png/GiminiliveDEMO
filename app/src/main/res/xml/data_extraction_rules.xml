<?xml version="1.0" encoding="utf-8"?><!--
   Sample data extraction rules file; uncomment and customize as necessary.
   See https://developer.android.com/about/versions/12/backup-restore#xml-changes
   for details.
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="sharedpref" path="GeminiPrefsEncrypted.xml"/>
        <exclude domain="sharedpref" path="GeminiPrefs.xml"/>
        <exclude domain="database" path="AssistantMeetings.db"/>
        <exclude domain="database" path="AssistantMemory.db"/>
        <exclude domain="database" path="vehicle_memory.db"/>
    </cloud-backup>
    <device-transfer>
        <exclude domain="sharedpref" path="GeminiPrefsEncrypted.xml"/>
        <exclude domain="sharedpref" path="GeminiPrefs.xml"/>
        <exclude domain="database" path="AssistantMeetings.db"/>
        <exclude domain="database" path="AssistantMemory.db"/>
        <exclude domain="database" path="vehicle_memory.db"/>
    </device-transfer>
</data-extraction-rules>
{
  "version": "1.0",
  "description": "Hermes Continuity Protocol Configuration - Level 3",
  "autoCheckpoint": {
    "enabled": true,
    "frequency": 3,
    "onError": true,
    "onDecision": true,
    "onTopicSwitch": false,
    "onHighImpactTool": true
  },
  "storage": {
    "checkpointsDir": "checkpoints",
    "privateDir": ".checkpoints",
    "maxCheckpoints": 50,
    "retentionDays": 90
  },
  "audit": {
    "maxDecisionsPerCheckpoint": 20,
    "groupByProject": true
  },
  "replay": {
    "showMemorySnapshot": false,
    "maxEntries": 100
  },
  "recover": {
    "autoRestoreMemory": true,
    "requireConfirmation": true,
    "defaultRecoverFromStatus": ["error", "failed", "cancelled"]
  },
  "project": {
    "name": "GeminiLiveDemo",
    "defaultTags": ["android", "gemini-live", "kotlin"]
  }
}
